# OhMyForm environment configuration
# Copy to app.env and adjust values as needed

# Timezone
TZ=America/New_York

# Host/domain
BASE_HOST_NAME=myhost
BASE_DOMAIN_NAME=example.com

# Admin account
APP_ADMIN_USER=admin
APP_ADMIN_PASS=changeme_admin_password

# Application secret (min 32 chars)
APP_SECRET_KEY=changeme_secret_key_min_32_chars

# Database (MongoDB)
DB_CREATE_DATABASE_NAME=ohmyform
DB_ADMIN_USER=root
DB_ADMIN_PASS=changeme_admin_password
